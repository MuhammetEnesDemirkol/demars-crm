      ]
    },
    "Get Pending Order": {
      "main": [
        [{"node": "Merge Order Data", "type": "main", "index": 0}]
      ]
    },
    "Merge Order Data": {
      "main": [
        [{"node": "Analyze Receipt GPT-4o", "type": "main", "index": 0}]
      ]
    },
    "Analyze Receipt GPT-4o": {
      "main": [
        [{"node": "Parse Receipt Result", "type": "main", "index": 0}]
      ]
    },
    "Parse Receipt Result": {
      "main": [
        [{"node": "Is Valid Receipt?", "type": "main", "index": 0}]
      ]
    },
    "Is Valid Receipt?": {
      "main": [
        [{"node": "PATCH Order payment_received", "type": "main", "index": 0}],
        [{"node": "Send WA Not a Receipt", "type": "main", "index": 0}]
      ]
    },
    "PATCH Order payment_received": {
      "main": [
        [{"node": "PATCH Conv active", "type": "main", "index": 0}]
      ]
    },
    "PATCH Conv active": {
      "main": [
