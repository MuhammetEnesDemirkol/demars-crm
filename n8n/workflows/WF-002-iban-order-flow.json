{
  "name": "WF-002 IBAN Order Flow",
  "nodes": [
    {
      "id": "n_webhook",
      "name": "Order Webhook",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 2,
      "position": [
        250,
        300
      ],
      "webhookId": "wf002-order-handler",
      "parameters": {
        "httpMethod": "POST",
        "path": "wf002-order",
        "responseMode": "responseNode",
        "options": {}
      }
    },
    {
      "id": "n_respond_200",
      "name": "Respond 200 OK",
      "type": "n8n-nodes-base.respondToWebhook",
      "typeVersion": 1.1,
      "position": [
        470,
        180
      ],
      "parameters": {
        "respondWith": "text",
        "responseBody": "OK",
        "responseCode": 200,
        "options": {}
      }
    },
    {
      "id": "n_route_case",
      "name": "Route by Case",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2,
      "position": [
        470,
        300
      ],
      "parameters": {
        "conditions": {
          "options": {
            "caseSensitive": true,
            "leftValue": "",
            "typeValidation": "strict"
          },
          "conditions": [
            {
              "id": "c1",
              "leftValue": "={{ $json.body.case }}",
              "rightValue": "order_intent",
              "operator": {
                "type": "string",
                "operation": "equals"
              }
            }
          ],
          "combinator": "and"
        }
      }
    },
    {
      "id": "n_extract_payload_a",
      "name": "Extract Payload (A)",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        690,
        180
      ],
      "parameters": {
        "jsCode": "const body = $input.item.json.body;\nreturn [{ json: { ...body } }];"
      }
    },
    {
      "id": "n_extract_payload_b",
      "name": "Extract Payload (B)",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        690,
        420
      ],
      "parameters": {
        "jsCode": "const body = $input.item.json.body;\nreturn [{ json: { ...body } }];"
      }
    },
    {
      "id": "n_gpt_extract_order",
      "name": "GPT Extract Order Details",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4,
      "position": [
        910,
        180
      ],
      "parameters": {
        "method": "POST",
        "url": "https://api.openai.com/v1/chat/completions",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Authorization",
              "value": "=Bearer {{ $env.OPENAI_API_KEY }}"
            },
            {
              "name": "Content-Type",
              "value": "application/json"
            }
          ]
        },
        "sendBody": true,
        "options": {},
        "contentType": "json",
        "jsonBody": "={\n  \"model\": \"gpt-4o-mini\",\n  \"max_tokens\": 200,\n  \"messages\": [\n    {\"role\": \"system\", \"content\": \"Müşteri mesajından sipariş detaylarını JSON olarak çıkar: {product_name, size, quantity, notes}. Bilgi yoksa null döndür. Sadece JSON döndür, başka açıklama ekleme.\"},\n    {\"role\": \"user\", \"content\": {{ JSON.stringify($json.message_text) }}}\n  ]\n}",
        "specifyBody": "json"
      }
    },
    {
      "id": "n_parse_order_details",
      "name": "Parse Order Details",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1130,
        180
      ],
      "parameters": {
        "jsCode": "const prev = $('Extract Payload (A)').item.json;\nlet productDetails = {};\ntry {\n  const raw = $input.item.json.choices?.[0]?.message?.content?.trim() || '{}';\n  const cleaned = raw.replace(/^```json\\s*/i, '').replace(/```\\s*$/, '').trim();\n  productDetails = JSON.parse(cleaned);\n} catch(e) {\n  productDetails = { parse_error: true };\n}\nreturn [{ json: { ...prev, product_details: productDetails } }];"
      }
    },
    {
      "id": "n_send_wa_address_request",
      "name": "Send WA Address Request",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4,
      "position": [
        1350,
        180
      ],
      "parameters": {
        "method": "POST",
        "url": "=https://graph.facebook.com/v21.0/{{ $json.firm_wa_phone_number_id }}/messages",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Authorization",
              "value": "=Bearer {{ $json.firm_wa_access_token }}"
            },
            {
              "name": "Content-Type",
              "value": "application/json"
            }
          ]
        },
        "sendBody": true,
        "options": {},
        "contentType": "json",
        "jsonBody": "={\n  \"messaging_product\": \"whatsapp\",\n  \"to\": \"{{ $json.customer_phone }}\",\n  \"type\": \"text\",\n  \"text\": { \"body\": \"Siparişinizi aldık! 🎉\\nTeslimat adresinizi paylaşır mısınız?\\n(İl, İlçe, Mahalle, Cadde/Sokak, Bina No, Daire No)\" }\n}",
        "specifyBody": "json"
      }
    },
    {
      "id": "n_patch_conv_awaiting_address",
      "name": "PATCH Conv awaiting_address",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4,
      "position": [
        1570,
        180
      ],
      "parameters": {
        "method": "PATCH",
        "url": "={{ $env.SUPABASE_URL }}/rest/v1/conversations",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "apikey",
              "value": "={{ $env.SUPABASE_SERVICE_KEY }}"
            },
            {
              "name": "Authorization",
              "value": "=Bearer {{ $env.SUPABASE_SERVICE_KEY }}"
            },
            {
              "name": "Content-Type",
              "value": "application/json"
            }
          ]
        },
        "sendQuery": true,
        "queryParameters": {
          "parameters": [
            {
              "name": "id",
              "value": "=eq.{{ $('Parse Order Details').item.json.conversation_id }}"
            }
          ]
        },
        "sendBody": true,
        "options": {},
        "contentType": "json",
        "jsonBody": "={\n  \"state\": \"awaiting_address\"\n}",
        "specifyBody": "json"
      }
    },
    {
      "id": "n_post_order_draft",
      "name": "POST Order Draft",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4,
      "position": [
        1790,
        180
      ],
      "parameters": {
        "method": "POST",
        "url": "={{ $env.SUPABASE_URL }}/rest/v1/orders",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "apikey",
              "value": "={{ $env.SUPABASE_SERVICE_KEY }}"
            },
            {
              "name": "Authorization",
              "value": "=Bearer {{ $env.SUPABASE_SERVICE_KEY }}"
            },
            {
              "name": "Content-Type",
              "value": "application/json"
            },
            {
              "name": "Prefer",
              "value": "return=representation"
            }
          ]
        },
        "sendBody": true,
        "options": {},
        "contentType": "json",
        "jsonBody": "={\n  \"firm_id\": \"{{ $('Parse Order Details').item.json.firm_id }}\",\n  \"customer_id\": \"{{ $('Parse Order Details').item.json.customer_id }}\",\n  \"conversation_id\": \"{{ $('Parse Order Details').item.json.conversation_id }}\",\n  \"product_details\": {{ JSON.stringify($('Parse Order Details').item.json.product_details) }},\n  \"status\": \"draft\"\n}",
        "specifyBody": "json"
      }
    },
    {
      "id": "n_notify_wf005_a",
      "name": "Notify WF-005 (A)",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4,
      "position": [
        2010,
        180
      ],
      "parameters": {
        "method": "POST",
        "url": "={{ $('Parse Order Details').item.json.wf005_webhook_url }}",
