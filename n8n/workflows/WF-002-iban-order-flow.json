          ]
        },
        "sendBody": true,
        "options": {},
        "contentType": "json",
        "jsonBody": "={\n  \"delivery_address\": {{ JSON.stringify($json.message_text) }},\n  \"status\": \"pending_payment\",\n  \"iban_sent_at\": \"{{ new Date().toISOString() }}\"\n}",
        "specifyBody": "json"
