        "jsonBody": "={\n  \"firm_id\": \"{{ $('Parse Order Details').item.json.firm_id }}\",\n  \"type\": \"new_order\",\n  \"title\": \"🛍️ Yeni sipariş niyeti\",\n  \"body\": \"Müşteri sipariş vermek istiyor. Adres bekleniyor.\",\n  \"data\": {}\n}",
        "specifyBody": "json"
      }
    },
    {
      "id": "n_get_draft_order",
      "name": "Get Draft Order",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4,
      "position": [
        910,
        420
      ],
      "parameters": {
        "method": "GET",
        "url": "={{ $env.SUPABASE_URL }}/rest/v1/orders",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "apikey",
