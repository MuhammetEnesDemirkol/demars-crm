          "parameters": [
            {
              "name": "conversation_id",
              "value": "=eq.{{ $json.conversation_id }}"
            },
            {
              "name": "status",
              "value": "=eq.draft"
            },
            {
              "name": "order",
              "value": "created_at.desc"
            },
            {
              "name": "limit",
              "value": "1"
            }
          ]
        },
        "options": {}
      }
    },
    {
      "id": "n_merge_order_b",
      "name": "Merge Order B",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1130,
        420
      ],
      "parameters": {
        "jsCode": "const ordersRaw = $input.item.json;\nconst orders = Array.isArray(ordersRaw) ? ordersRaw : [ordersRaw];\nconst order = orders[0] || {};\nconst prev = $('Extract Payload (B)').item.json;\nreturn [{ json: { ...prev, order_id: order.id, order_number: order.order_number || order.id } }];"
      }
    },
