        "sendBody": true,
        "bodyContentType": "json",
        "body": "={\n  \"model\": \"gpt-4o\",\n  \"max_tokens\": 500,\n  \"messages\": [\n    {\"role\": \"system\", \"content\": {{ JSON.stringify($json.system_prompt) }}},\n    ...{{ JSON.stringify($json.history_messages) }},\n    {\"role\": \"user\", \"content\": {{ JSON.stringify($json.message_text) }}}\n  ]\n}",
        "options": {}
      }
    },
    {
      "id": "n_extract_response",
      "name": "Extract AI Response",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        5090,
        600
      ],
      "parameters": {
        "jsCode": "const aiText = $input.item.json.choices?.[0]?.message?.content?.trim() || 'Üzgünüm, şu anda cevap veremiyorum. Lütfen daha sonra tekrar deneyin.';\nconst prev = $('Build AI Prompt').item.json;\n\nreturn [{\n  json: {\n    ...prev,\n    ai_response_text: aiText\n  }\n}];"
      }
    },
