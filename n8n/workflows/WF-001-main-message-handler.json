      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        3330,
        420
      ],
      "parameters": {
        "jsCode": "// Restore full context after HTTP nodes that lose it\n// Try each possible upstream merge node\nlet prev;\ntry { prev = $('Merge Existing Conversation').item.json; } catch(e) {}\nif (!prev || !prev.conversation_id) {\n  try { prev = $('Merge New Conversation').item.json; } catch(e) {}\n}\nreturn [{ json: { ...prev } }];"
      }
    },
