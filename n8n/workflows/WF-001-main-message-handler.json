      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1350,
        420
      ],
      "parameters": {
        "jsCode": "const firmArray = $input.item.json;\nconst firm = Array.isArray(firmArray) ? firmArray[0] : firmArray;\nconst prev = $('Extract Message Data').item.json;\n\nreturn [{\n  json: {\n    ...prev,\n    firm_id: firm.id,\n    firm_name: firm.name,\n    firm_iban: firm.iban,\n    firm_iban_holder: firm.iban_holder_name,\n    firm_wa_access_token: firm.wa_access_token,\n    firm_wa_phone_number_id: firm.wa_phone_number_id,\n    firm_owner_phone: firm.whatsapp_phone,\n    firm_shipping: firm.shipping_instructions\n  }\n}];"
      }
    },
